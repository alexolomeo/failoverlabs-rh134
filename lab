#!/bin/bash

MAINPATH=/usr/local/rh134
LABS_DIR="$MAINPATH/labs"

#LABS_DIR="$(dirname "$0")/labs"

ACTION="$1"
LAB_NAME="$2"
LAB_PATH="$LABS_DIR/$LAB_NAME"

# Función para listar labs
list_labs() {
    echo "Labs disponibles:"
    for lab in "$LABS_DIR"/*/; do
        if [[ -d "$lab" ]]; then
            echo "- $(basename "$lab")"
        fi
    done
}

FLAG_PATH="/tmp/$LAB_NAME/active-simulate"

# Función para validar un solo intento
check_play_lab() {
    if [ -f "$FLAG_PATH" ]; then
        echo "No puedes volver a evaluar, ejecuta nuevamente: lab start $LAB_NAME"
        exit 1
    fi

    echo "Iniciando simulación..."
    # Aquí iría el resto de tu lógica de simulación
}

# Función para ver a la espiracion
check_expire_lab() {

    FILE_PATH="/tmp/$LAB_NAME/init-lab"

    if [ -f "$FILE_PATH" ]; then
	FECHA_STR=$(grep 'hora_inicio=' $FILE_PATH | tail -n 1 | cut -d'=' -f2)

	# La fecha viene como: 2026-04-22 10:46:31
	INICIO_SEC=$(date -d "$FECHA_STR" +%s)
	AHORA_SEC=$(date +%s)

	# Calcular diferencia en segundos y convertir a minutos
	DIFERENCIA_SEC=$(( AHORA_SEC - INICIO_SEC ))
	DIFERENCIA_MIN=$(( DIFERENCIA_SEC / 60 ))

	# 4. Validar si supera los 10 minutos
	if [ "$DIFERENCIA_MIN" -gt 10 ]; then
	    echo "	--------------------------------------------------------------"
	    echo "		ALERTA: Han pasado más de 10 minutos ($DIFERENCIA_MIN min)."
	    echo "		Ejecutar nuevamente: lab start selinux-opsmode             "	
	    echo "	--------------------------------------------------------------"
	    exit 1
	else
	    echo "Validación correcta: Dentro del tiempo permitido. Continuando..."
	fi
    fi
}

# Validación básica
if [[ -z "$ACTION" ]]; then
    echo "Uso: lab {start|simulate|grade|finish|list|info} <nombre-del-lab>"
    exit 1
fi

LOG_FILE="/var/log/labtool.log"

log_action() {
    local action="$1"
    local lab_name="$2"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Acción: $action, Lab: $lab_name" >> "$LOG_FILE"
}

# Llamada a log_action en cada acción
case "$ACTION" in
    start)
        log_action "start" "$LAB_NAME"
        if [[ -x "$LAB_PATH/setup.sh" ]]; then
            echo "Iniciando laboratorio: $LAB_NAME"
            "$LAB_PATH/setup.sh"
        else
            echo "No hay script de inicio (setup.sh)"
        fi
        ;;
    simulate)
        log_action "simulate" "$LAB_NAME"
	check_play_lab
	check_expire_lab
        if [[ -x "$LAB_PATH/simulate.sh" ]]; then
            echo "Simulador ...Evaluando laboratorio: $LAB_NAME"
            "$LAB_PATH/simulate.sh"
	    cat /tmp/selinux-opsmode/simulate.log
        else
            echo "No hay script de evaluación (simulate.sh)"
        fi
        ;;
    grade)
        log_action "grade" "$LAB_NAME"
        if [[ -x "$LAB_PATH/grade.sh" ]]; then
            echo "Evaluando laboratorio: $LAB_NAME"
            "$LAB_PATH/grade.sh"
        else
            echo "No hay script de evaluación (grade.sh)"
        fi
        ;;
    finish)
        log_action "finish" "$LAB_NAME"
        if [[ -x "$LAB_PATH/cleanup.sh" ]]; then
            echo "Finalizando laboratorio: $LAB_NAME"
            "$LAB_PATH/cleanup.sh"
        else
            echo "No hay script de limpieza (cleanup.sh)"
        fi
        ;;
    list)
        log_action "list" "N/A"
        list_labs
        ;;
    info)
        log_action "info" "$LAB_NAME"
        if [[ -d "$LAB_PATH" ]]; then
            echo "Información sobre el lab '$LAB_NAME':"
            if [[ -f "$LAB_PATH/instructions.txt" ]]; then
                cat "$LAB_PATH/instructions.txt"
            else
                echo "No hay instrucciones disponibles para este laboratorio."
            fi
        else
            echo "El laboratorio '$LAB_NAME' no existe."
        fi
        ;;
    *)
        echo "Acción inválida: $ACTION"
        exit 1
        ;;
esac
